---
import EducationCard from "./Cards/EducationCard.astro";

const education = [
    {
        title: "Tecnología en Análisis y Desarrollo de Software",
        description: "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat",
        from: "2023",
        to: "2026",
        institution: "SENA"
    },
    {
        title: "Ingeniería de Sistemas y Computación",
        description: "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat",
        from: "2026",
        to: "Presente",
        institution: "Universidad Central (Colombia)"
    }
]

---


<section id="education" class="py-12">
    <div class="flex flex-col items-stretch justify-start gap-8">
        <h2 class="text-2xl md:text-3xl font-medium tracking-tight text-white"> 
            Educación
        </h2>

    <div class="grid grid-cols-1 sm:grid-cols-1 lg:grid-cols-1 xl:grid-cols-1 gap-8">
        {education.map(educacion => (
            <EducationCard
            title={educacion.title}
            description={educacion.description}
            from={educacion.from}
            to={educacion.to}
            institution={educacion.institution}
            />
        ))}
    </div>
   </div>
</section>