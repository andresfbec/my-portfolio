---
const { from, to, description, position, company, url} = Astro.props;
// videoId = solo el ID de YouTube, ej: "ABC123XYZ" (no la url completa)
---

<div
    class="
    project-card
    group
    relative
    flex
    flex-col
    md:flex-row
    items-stretch
    gap-4
    rounded-lg
    p-4
    transition-all
    duration-300
    bg-transparent
    hover:bg-white/[0.02]
    hover:-translate-y-1
    hover:shadow-[0_20px_45px_rgba(0,0,0,0.35),0_0_35px_rgba(255,255,255,0.08)]
    w-full
    "
>

    <!-- tiempo en la compañia -->
    <div class="flex flex-col items-start justify-start gap-1 md:w-40 pt-3">
        <p class="text-sm font-semibold text-white">{from} - {to}</p>
    </div>

    <!-- Contenido -->
    <div class="flex flex-1 flex-col justify-center px-1 py-2 text-left md:pl-2">

        <!-- Primera línea -->
        <div class="flex justify-between items-center gap-2">

            <h3 class="text-xl font-semibold text-white">
                {position}
            </h3>

            <span class="text-zinc-400">
                {company}
            </span>

        </div>

        <!-- Segunda línea -->
        <p class="mt-3 text-sm leading-relaxed text-slate-300">
            {description}
        </p>

    </div>
</div>