---
// src/components/Hero.astro
---
<section class="pt-32 pb-12" id="hero">
  <div class="flex flex-col md:flex-row items-start md:items-center gap-8 px-4 md:px-0">
    
    <!-- Foto de Perfil Izquierda -->
    <div class="relative min-w-[120px] md:min-w-[150px]">
      <img 
        src="../../public/avatar-portfolio.jpg" 
        alt="." 
        class="w-28 h-28 md:w-36 md:h-36 rounded-full object-cover border border-white/10 shadow-2xl"
        loading="eager" 
      />
    </div>

    <!-- Títulos Principales Derecha -->
    <div class="space-y-2">
      <h1 class="text-3xl md:text-5xl font-medium tracking-tight text-white">
        Desarrollador de Software Junior
      </h1>
      <p class="text-lg md:text-xl text-zinc-400 font-light">
        ¡Hola! Mi nombre es Andrés Felipe Becerra.
      </p>
    </div>

  </div>

  <!-- Texto de Introducción -->
  <div class="mt-8 max-w-3xl px-4 md:px-0">
    <p class="leading-relaxed text-zinc-300 text-base md:text-lg font-light text-left">
      Desarrollador de software junior con enfoque en frontend, especializado en construir interfaces modernas y centradas en el usuario. 
      Manejo React, Django, Flutter y APIs REST, con bases en SQL y Linux. 
      Próximo a iniciar Ingeniería de Sistemas, buscando consolidarme como desarrollador full-stack.
    </p>
    
    <!-- Botón Único de Acción: Descargar CV -->
    <div class="mt-8 flex flex-wrap items-center justify-start gap-3">
        <div class="group relative p-[1px] inline-flex items-center justify-start rounded-xl overflow-hidden bg-white/10 transition-all duration-300">
            <div class="absolute inset-[-1000%] bg-[conic-gradient(from_90deg_at_50%_50%,transparent_0%,transparent_70%,#B5B1B1_100%)] opacity-0 group-hover:opacity-100 transition-opacity duration-500 animate-border-spin"></div>

            <a
                href="/CV_Andres_Becerra.pdf"
                download
                class="relative flex items-center gap-2 px-5 py-2.5 text-sm rounded-[11px] bg-black/80 backdrop-blur-md text-white w-full h-full border border-white/5 group-hover:border-transparent transition-colors duration-300"
            >
                <svg
                    class="w-4 h-4 text-zinc-400 group-hover:text-white transition-colors duration-300"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3"/>
                </svg>
                <span class="font-medium tracking-wide">Descargar CV</span>
            </a>
        </div>

        <a
            href="https://www.linkedin.com/in/andrés-becerra-malaver-0b6561332"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-white/5 text-zinc-300 transition hover:-translate-y-0.5 hover:bg-white/10 hover:text-white"
        >
            <img src="/icons/linkedin.svg" alt="LinkedIn" class="h-5 w-5 object-contain brightness-0 invert" />
        </a>

        <a
            href="https://github.com/andresfbec"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-white/5 text-zinc-300 transition hover:-translate-y-0.5 hover:bg-white/10 hover:text-white"
        >
            <img src="/icons/github.svg" alt="GitHub" class="h-5 w-5 object-contain brightness-0 invert" />
        </a>

        <a
            href="mailto:becerrafelipe8b@gmail.com"
            aria-label="Gmail"
            class="flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-white/5 text-zinc-300 transition hover:-translate-y-0.5 hover:bg-white/10 hover:text-white"
        >
            <img src="/icons/gmail.svg" alt="Gmail" class="h-5 w-5 object-contain brightness-0 invert" />
        </a>

        <style>
            @keyframes border-spin {
                from {
                    transform: rotate(0deg);
                }
                to {
                    transform: rotate(360deg);
                }
            }

            .animate-border-spin {
                animation: border-spin 3s linear infinite;
            }
        </style>
    </div>
  </div>
</section>