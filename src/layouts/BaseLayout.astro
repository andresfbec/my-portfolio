---
import "../styles/global.css"; //estilos globales
// import "@fontsource-variable/onest"; //fuente a usar en la pagina 
import '@fontsource-variable/onest/index.css';
---
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <title>Portafolio Andrés Becerra</title>
    </head>
    
<body
    class="min-h-screen w-screen text-white p-4 box-border overflow-y-auto overflow-x-hidden
            bg-black
            bg-[linear-gradient(115deg,_#000_0%,_#000_40%,_#3a332c_58%,_#000_72%,_#000_100%)]
            relative"
    >

    <!-- capa de grano fuerte, sin blend mode para q se note completo -->
    <div
        class="fixed inset-0 pointer-events-none opacity-[0.35] mix-blend-hard-light"
        style="background-image: url(&quot;data:image/svg+xml;base64,&quot;); background-size: 180px 180px;"
    ></div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <slot />
    </div>
</body>

</html>